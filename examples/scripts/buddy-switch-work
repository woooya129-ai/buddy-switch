#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${BUDDY_SWITCH_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/buddy-switch/config.env}"
if [[ -f "$CONFIG_FILE" ]]; then
  # The config is sourced as shell. Refuse it if group/others can write to it,
  # otherwise a writable config becomes command injection into this script.
  config_perm="$(stat -f '%Lp' "$CONFIG_FILE" 2>/dev/null || stat -c '%a' "$CONFIG_FILE" 2>/dev/null || echo '')"
  if [[ -n "$config_perm" ]] && [[ "$config_perm" =~ [2367].$ || "$config_perm" =~ [2367]$ ]]; then
    printf '%s\n' "Refusing to load $CONFIG_FILE: it is group/world-writable. Run: chmod 600 $CONFIG_FILE" >&2
    exit 1
  fi
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

FRIEND_PROFILE="${FRIEND_PROFILE:-buddy-friend}"
WORK_PROFILE="${WORK_PROFILE:-buddy-work}"
HERMES_BIN="${HERMES_BIN:-hermes}"
OLLAMA_BIN="${OLLAMA_BIN:-ollama}"
OLLAMA_PORT="${OLLAMA_PORT:-11434}"
LOG_DIR="${BUDDY_SWITCH_LOG_DIR:-$HOME/.local/state/buddy-switch}"
LOG_FILE="$LOG_DIR/mode-switch.log"

# Keep switch logs private to the current user.
umask 077
mkdir -p "$LOG_DIR"

(
  set -euo pipefail

  if command -v lsof >/dev/null 2>&1; then
    if ! lsof -nP -iTCP:"$OLLAMA_PORT" -sTCP:LISTEN >/dev/null 2>&1; then
      if [[ "${BUDDY_SWITCH_START_OLLAMA_APP:-0}" == "1" ]] && command -v open >/dev/null 2>&1; then
        open -a Ollama || true
      fi
      for _ in {1..30}; do
        lsof -nP -iTCP:"$OLLAMA_PORT" -sTCP:LISTEN >/dev/null 2>&1 && break
        sleep 1
      done
    fi
  fi

  if [[ -n "${FRIEND_MODEL:-}" ]]; then
    "$OLLAMA_BIN" stop "$FRIEND_MODEL" >/dev/null 2>&1 || true
  fi

  "$HERMES_BIN" -p "$FRIEND_PROFILE" gateway stop >/dev/null 2>&1 || true
  "$HERMES_BIN" gateway stop >/dev/null 2>&1 || true
  "$HERMES_BIN" -p "$WORK_PROFILE" gateway start
) >>"$LOG_FILE" 2>&1 &

printf '%s\n' "Switching to work mode. Send another message in 10-20 seconds."
