#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/buddy-switch"
CONFIG_FILE="${BUDDY_SWITCH_CONFIG:-$CONFIG_DIR/config.env}"
if [[ -f "$CONFIG_FILE" ]]; then
  # The config is sourced as shell. Refuse it if group/others can write to it,
  # otherwise a writable config becomes command injection into this script.
  config_perm="$(stat -f '%Lp' "$CONFIG_FILE" 2>/dev/null || stat -c '%a' "$CONFIG_FILE" 2>/dev/null || echo '')"
  if [[ -n "$config_perm" ]] && [[ "$config_perm" =~ [2367].$ || "$config_perm" =~ [2367]$ ]]; then
    printf '%s\n' "Refusing to load $CONFIG_FILE: it is group/world-writable. Run: chmod 600 $CONFIG_FILE" >&2
    exit 1
  fi
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

FRIEND_PROFILE="${FRIEND_PROFILE:-buddy-friend}"
WORK_PROFILE="${WORK_PROFILE:-buddy-work}"
FRIEND_NAME="${FRIEND_NAME:-Friend}"
FRIEND_PERSONA_NAME="${FRIEND_PERSONA_NAME:-friend SOUL}"
HERMES_BIN="${HERMES_BIN:-hermes}"
OLLAMA_BIN="${OLLAMA_BIN:-ollama}"
OLLAMA_PORT="${OLLAMA_PORT:-11434}"
PROXY_PORT="${BUDDY_NOTHINK_PROXY_PORT:-11435}"
PROXY_BIN="${BUDDY_NOTHINK_PROXY_BIN:-$HOME/.local/bin/nothink_proxy.py}"
LOG_DIR="${BUDDY_SWITCH_LOG_DIR:-$HOME/.local/state/buddy-switch}"
LOG_FILE="$LOG_DIR/mode-switch.log"
CURRENT_ROUTE_FILE="${BUDDY_SWITCH_CURRENT_ROUTE_FILE:-$LOG_DIR/current-route}"
SWITCH_STATUS_FILE="${BUDDY_SWITCH_STATUS_FILE:-$LOG_DIR/switch-status}"
SWITCH_UPDATED_FILE="${BUDDY_SWITCH_UPDATED_FILE:-$LOG_DIR/switch-updated-at}"
SWITCH_LOCK_DIR="${BUDDY_SWITCH_LOCK_DIR:-$LOG_DIR/switch.lock}"

# Keep switch logs private to the current user.
umask 077
mkdir -p "$LOG_DIR"

write_switch_state() {
  local status="$1"
  local route="$2"
  local temp_status="${SWITCH_STATUS_FILE}.tmp.$$"
  local temp_updated="${SWITCH_UPDATED_FILE}.tmp.$$"

  printf '%s %s\n' "$status" "$route" >"$temp_status"
  printf '%s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" >"$temp_updated"
  mv -f "$temp_status" "$SWITCH_STATUS_FILE"
  mv -f "$temp_updated" "$SWITCH_UPDATED_FILE"
}

if ! mkdir "$SWITCH_LOCK_DIR" 2>/dev/null; then
  printf '%s\n' 'A Buddy Switch route change is already running. Use /friends to check it before pressing another route.'
  exit 3
fi

write_switch_state switching friend

(
  set -euo pipefail
  cleanup_switch() {
    local rc="$?"
    if [[ "$rc" -ne 0 ]]; then
      write_switch_state failed friend
    fi
    rmdir "$SWITCH_LOCK_DIR" 2>/dev/null || true
  }
  trap cleanup_switch EXIT

  if command -v lsof >/dev/null 2>&1; then
    if ! lsof -nP -iTCP:"$OLLAMA_PORT" -sTCP:LISTEN >/dev/null 2>&1; then
      if [[ "${BUDDY_SWITCH_START_OLLAMA_APP:-0}" == "1" ]] && command -v open >/dev/null 2>&1; then
        open -a Ollama || true
      fi
      for _ in {1..30}; do
        lsof -nP -iTCP:"$OLLAMA_PORT" -sTCP:LISTEN >/dev/null 2>&1 && break
        sleep 1
      done
    fi
  fi

  if command -v lsof >/dev/null 2>&1; then
    if ! lsof -nP -iTCP:"$PROXY_PORT" -sTCP:LISTEN >/dev/null 2>&1; then
      if [[ -x "$PROXY_BIN" ]]; then
        nohup env OLLAMA_NOTHINK_PROXY_PORT="$PROXY_PORT" "$PROXY_BIN" \
          >>"$LOG_DIR/nothink-proxy.log" 2>&1 &
      fi
    fi
  fi

  if [[ -n "${WORK_MODEL:-}" ]]; then
    "$OLLAMA_BIN" stop "$WORK_MODEL" >/dev/null 2>&1 || true
  fi

  "$HERMES_BIN" -p "$WORK_PROFILE" gateway stop >/dev/null 2>&1 || true
  "$HERMES_BIN" gateway stop >/dev/null 2>&1 || true
  "$HERMES_BIN" -p "$FRIEND_PROFILE" gateway start
  printf '%s\n' 'friend' >"$CURRENT_ROUTE_FILE"
  write_switch_state active friend
) >>"$LOG_FILE" 2>&1 &

cat <<EOF
Buddy Switch

Requested:   $FRIEND_NAME
Profile:     $FRIEND_PROFILE
Model:       ${FRIEND_MODEL:-profile default}
Personality: $FRIEND_PERSONA_NAME
Status:      SWITCHING (not confirmed yet)

Run /friends in 10-20 seconds. Only ACTIVE means the gateway switch succeeded.
EOF
